{
  "name": "runapi-ai/kling",
  "description": "RunAPI Kling Composer package for PHP applications",
  "type": "library",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "RunAPI",
      "email": "contact@runapi.ai"
    }
  ],
  "require": {
    "php": ">=8.2",
    "runapi-ai/core": "^0.2.2"
  },
  "autoload": {
    "psr-4": {
      "RunApi\\Kling\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "RunApi\\Kling\\Tests\\": "tests/",
      "RunApi\\Core\\Tests\\": "tests/Support/CoreTests/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-main": "0.1.x-dev"
    }
  },
  "minimum-stability": "stable",
  "homepage": "https://runapi.ai/models/kling",
  "support": {
    "source": "https://github.com/runapi-ai/kling-php",
    "docs": "https://runapi.ai/docs#sdk-kling",
    "issues": "https://github.com/runapi-ai/kling-php/issues"
  },
  "keywords": [
    "runapi",
    "runapi-ai",
    "php",
    "composer",
    "sdk",
    "api",
    "packagist",
    "kling",
    "kling-api"
  ],
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "scripts": {
    "test": "phpunit -c phpunit.xml.dist"
  }
}
